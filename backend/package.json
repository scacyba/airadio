{
  "name": "airadio-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node scripts/seed-news-scripts.js && node scripts/seed-tracks.js",
    "db:seed:news": "node scripts/seed-news-scripts.js",
    "db:seed:tracks": "node scripts/seed-tracks.js",
    "db:seed:tracks:youtube": "node scripts/seed-tracks.js --resolve-youtube"
  },
  "dependencies": {
    "express": "^4.19.2",
    "uuid": "^11.0.3",
    "drizzle-orm": "^0.44.5",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4"
  }
}
